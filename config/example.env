# SeasonalWeather — secrets and Wine/process-level environment
# Copy to: /etc/seasonalweather/seasonalweather.env
# Then fill in the required values and restart.
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │  ALL behaviour configuration lives in config.yaml.                 │
# │  This file holds ONLY:                                             │
# │    1. Credentials / secrets                                        │
# │    2. Wine subprocess environment vars (VoiceText Paul only)       │
# └─────────────────────────────────────────────────────────────────────┘

# =============================================================
# REQUIRED — NWWS-OI XMPP credentials
# Register at https://www.weather.gov/nwws/
# =============================================================
NWWS_JID=CHANGEME@nwws-oi.weather.gov
NWWS_PASSWORD=CHANGEME

# =============================================================
# REQUIRED — Icecast source password
# Must match /etc/icecast2/icecast.xml and /etc/seasonalweather/radio.liq
# =============================================================
ICECAST_SOURCE_PASSWORD=CHANGEME
# ICECAST_ADMIN_PASSWORD=CHANGEME
# ICECAST_RELAY_PASSWORD=CHANGEME

# =============================================================
# OPTIONAL — Liquidsoap telnet
# Only set if you moved the port away from the default in radio.liq
# =============================================================
# LIQUIDSOAP_TELNET_HOST=127.0.0.1
# LIQUIDSOAP_TELNET_PORT=1234

# =============================================================
# OPTIONAL — HTTP API authentication
# Use SEASONAL_API_TOKENS_JSON for multiple named tokens with
# per-token scopes. Use SEASONAL_API_TOKEN for a single token.
# Leave both unset to disable bearer-token auth entirely.
# =============================================================
# SEASONAL_API_TOKEN=CHANGEME

# Multi-token example (JSON object: token -> {subject, scopes}):
# SEASONAL_API_TOKENS_JSON='{
#   "mytoken": {
#     "subject": "my-client",
#     "scopes": ["read:health", "read:status", "read:alerts", "read:config"]
#   }
# }'

# =============================================================
# VoiceText Paul — Wine/subprocess environment variables
#
# These are NOT read by Python. They are passed directly into
# the Wine subprocess environment by voicetext_paul_synth.
# Only relevant if tts.backend = voicetext_paul in config.yaml.
# Behaviour knobs (retries, run_as, etc.) are in config.yaml.
# =============================================================
# VOICETEXT_DEBUG=1
# VOICETEXT_PAUL_LOCK_WAIT=90
# VOICETEXT_PAUL_WINEDEBUG=-all,+seh,+tid,+timestamp
# VOICETEXT_PAUL_WINEESYNC=0
# VOICETEXT_PAUL_WINEFSYNC=0
# VOICETEXT_PAUL_DISABLE_WRITE_WATCH=1
# VOICETEXT_PAUL_CORE=unlimited

# ===========================================================
# Discord Webhook — Logger environment variables
#
# Read by config.py and injected into discord_log.py for
# logging purposes. That's all they do.
#
# If a URL is empty or unset, that channel is silently
# disabled regardless of the *_enabled knobs in config.yaml.
# Webhook URLs are treated as secrets — never commit them.
# ===========================================================
SEASONAL_DISCORD_ALERTS_WEBHOOK=
SEASONAL_DISCORD_OPS_WEBHOOK=
SEASONAL_DISCORD_ERRORS_WEBHOOK=
SEASONAL_DISCORD_API_WEBHOOK=
